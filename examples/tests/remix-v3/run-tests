#!/usr/bin/env bash
set -euo pipefail

dir="$(cd "$(dirname "$0")" && pwd)"
root="$(cd "$dir/../.." && pwd)"  # examples/

NODEJS=$(nix-build --no-out-link '<nixpkgs>' -A nodejs_22 2>/dev/null)
NODE="$NODEJS/bin/node"

NM_DRV=$(nix-build --no-out-link "$root/nix/remix-v3.nix" -A nodeModules 2>/dev/null)
NM="$NM_DRV/node_modules"
export NODE_PATH="$NM"

echo "--- Test 1: @remix-run/dom (scoped, experimental version) ---"
"$NODE" -e '
  const dom = require("@remix-run/dom");
  const exports = Object.keys(dom);
  if (exports.length === 0) throw new Error("no exports");
  console.log("@remix-run/dom: " + exports.length + " exports");
  console.log("OK: scoped experimental package loaded");
'

echo ""
echo "--- Test 2: @remix-run/fetch-router (scoped, with deps) ---"
"$NODE" -e '
  const router = require("@remix-run/fetch-router");
  if (!router.createRouter) throw new Error("missing createRouter");
  console.log("@remix-run/fetch-router: createRouter present (" + Object.keys(router).length + " exports)");
  console.log("OK: fetch-router loaded with transitive deps");
'

echo ""
echo "--- Test 3: @tanstack/query-core ---"
"$NODE" -e '
  const qc = require("@tanstack/query-core");
  if (!qc.QueryClient) throw new Error("missing QueryClient");
  console.log("@tanstack/query-core: QueryClient present (" + Object.keys(qc).length + " exports)");
  console.log("OK: tanstack query-core loaded");
'

echo ""
echo "--- Test 4: alien-signals (reactive primitives) ---"
"$NODE" -e '
  const { signal, computed, effect } = require("alien-signals");
  const count = signal(0);
  const doubled = computed(() => count() * 2);
  if (doubled() !== 0) throw new Error("expected 0");
  count(5);
  if (doubled() !== 10) throw new Error("expected 10, got " + doubled());
  console.log("alien-signals: signal(5) → computed doubled = " + doubled());
  console.log("OK: reactive primitives work");
'

echo ""
echo "--- Test 5: remix-auth-oauth2 ---"
"$NODE" -e '
  const { OAuth2Strategy } = require("remix-auth-oauth2");
  if (!OAuth2Strategy) throw new Error("missing OAuth2Strategy");
  console.log("remix-auth-oauth2: OAuth2Strategy present");
  console.log("OK: auth strategy loaded");
'

echo ""
echo "--- Test 6: pnpm layout structure ---"
# Check .pnpm/ entries exist for key packages
for pkg in "@remix-run+dom@0.0.0-experimental-remix-jam.6" "@tanstack+query-core@5.90.20" "alien-signals@3.1.2"; do
  if [ ! -d "$NM/.pnpm/$pkg" ]; then
    echo "FAIL: .pnpm/$pkg missing"
    exit 1
  fi
done
echo "  .pnpm/ entries present for remix-run/dom, tanstack/query-core, alien-signals"

# Check dep symlinks within .pnpm/ entries
router_pnpm="$NM/.pnpm/@remix-run+fetch-router@0.6.0/node_modules"
if [ -d "$router_pnpm" ]; then
  for dep in "@remix-run/events"; do
    if [ -e "$router_pnpm/$dep" ]; then
      echo "  fetch-router has $dep dep linked"
    fi
  done
fi
echo "OK: pnpm layout correct"

echo ""
echo "All remix-v3 tests passed."
