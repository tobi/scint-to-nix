#!/usr/bin/env bash
set -euo pipefail

dir="$(cd "$(dirname "$0")" && pwd)"
root="$(cd "$dir/../.." && pwd)"  # examples/

# Use nix nodejs to match build-time node version
NODEJS=$(nix-build --no-out-link '<nixpkgs>' -A nodejs_22 2>/dev/null)
NODE="$NODEJS/bin/node"

NM_DRV=$(nix-build --no-out-link "$root/nix/node-basic.nix" -A nodeModules 2>/dev/null)
NM="$NM_DRV/node_modules"
export NODE_PATH="$NM"

echo "--- Test 1: pure JS package (ms) ---"
"$NODE" -e '
  const ms = require("ms");
  const result = ms(3600000);
  if (result !== "1h") throw new Error("expected 1h, got " + result);
  console.log("ms " + require("ms/package.json").version + ": " + result);
  console.log("OK: pure JS package loaded");
'

echo ""
echo "--- Test 2: scoped package (@types/node) ---"
"$NODE" -e '
  const pkg = require("@types/node/package.json");
  if (!pkg.name.startsWith("@types/")) throw new Error("expected scoped name");
  console.log(pkg.name + " " + pkg.version + ": loaded");
  console.log("OK: scoped package loaded");
'

echo ""
echo "--- Test 3: package with transitive deps (semver) ---"
"$NODE" -e '
  const semver = require("semver");
  if (!semver.valid("1.2.3")) throw new Error("semver.valid failed");
  if (!semver.gt("2.0.0", "1.0.0")) throw new Error("semver.gt failed");
  if (!semver.satisfies("1.2.3", "^1.0.0")) throw new Error("semver.satisfies failed");
  console.log("semver " + require("semver/package.json").version + ": valid, gt, satisfies all work");
  console.log("OK: package with logic loaded and tested");
'

echo ""
echo "--- Test 4: Express app boot (transitive dep tree) ---"
"$NODE" -e '
  const express = require("express");
  const app = express();
  app.get("/", (req, res) => res.send("hello from nix"));
  const server = app.listen(0, () => {
    const port = server.address().port;
    const http = require("http");
    http.get("http://localhost:" + port + "/", (res) => {
      let data = "";
      res.on("data", c => data += c);
      res.on("end", () => {
        if (data !== "hello from nix") throw new Error("expected hello from nix, got: " + data);
        console.log("express " + require("express/package.json").version + ": " + data);
        console.log("OK: Express app booted and responds");
        server.close();
      });
    });
  });
'

echo ""
echo "--- Test 5: native extension (better-sqlite3) ---"
"$NODE" -e '
  const Database = require("better-sqlite3");
  const db = new Database(":memory:");
  db.exec("CREATE TABLE t (id INTEGER PRIMARY KEY, name TEXT)");
  db.prepare("INSERT INTO t VALUES (1, ?)").run("pnpm-nix");
  const row = db.prepare("SELECT name FROM t WHERE id = 1").get();
  if (row.name !== "pnpm-nix") throw new Error("expected pnpm-nix, got " + row.name);
  console.log("better-sqlite3 " + require("better-sqlite3/package.json").version + ": " + row.name);
  console.log("OK: native extension compiled and works");
'

echo ""
echo "--- Test 6: bin entries (tsc, esbuild, semver) ---"
for pkg_name in typescript esbuild semver; do
  pkg_path=$(nix-build --no-out-link "$root/nix/node-basic.nix" -A "$pkg_name@*" 2>/dev/null || true)
  if [ -z "$pkg_path" ]; then
    # Try exact version
    case $pkg_name in
      typescript) pkg_path=$(nix-build --no-out-link -E "(import $root/nix/node-basic.nix {}).\"typescript@5.7.3\"" 2>/dev/null) ;;
      esbuild) pkg_path=$(nix-build --no-out-link -E "(import $root/nix/node-basic.nix {}).\"esbuild@0.24.2\"" 2>/dev/null) ;;
      semver) pkg_path=$(nix-build --no-out-link -E "(import $root/nix/node-basic.nix {}).\"semver@7.7.1\"" 2>/dev/null) ;;
    esac
  fi
  if [ -n "$pkg_path" ] && [ -d "$pkg_path/node_modules/.bin" ]; then
    bins=$(ls "$pkg_path/node_modules/.bin" | tr '\n' ' ')
    echo "  $pkg_name: $bins"
  else
    echo "  $pkg_name: (checking via nodeModules)"
  fi
done

# Verify tsc runs from nodeModules .bin
if [ -L "$NM/.bin/tsc" ]; then
  # tsc binary is in nodeModules, use nix node to run it
  version=$("$NODE" "$NM/.bin/tsc" --version 2>&1 || "$NM/.bin/tsc" --version 2>&1 || echo "unknown")
  echo "  tsc --version: $version"
fi
echo "OK: bin entries verified"

echo ""
echo "--- Test 7: pnpm layout structure ---"
# Verify .pnpm/ virtual store exists with proper nesting
if [ ! -d "$NM/.pnpm" ]; then
  echo "FAIL: .pnpm/ directory missing"
  exit 1
fi

# Check that express has its deps symlinked inside .pnpm/
express_pnpm="$NM/.pnpm/express@4.21.2/node_modules"
if [ ! -d "$express_pnpm" ]; then
  echo "FAIL: express .pnpm entry missing"
  exit 1
fi

# Verify express can see its deps within the .pnpm/ entry
for dep in body-parser cookie debug; do
  if [ ! -e "$express_pnpm/$dep" ]; then
    echo "FAIL: express dep $dep not linked in .pnpm entry"
    exit 1
  fi
done
echo "  express .pnpm/ entry has body-parser, cookie, debug deps"

# Verify better-sqlite3 can see bindings in .pnpm/
bs_pnpm="$NM/.pnpm/better-sqlite3@11.8.1/node_modules"
if [ -d "$bs_pnpm" ] && [ -e "$bs_pnpm/bindings" ]; then
  echo "  better-sqlite3 .pnpm/ entry has bindings dep"
fi

# Verify top-level symlinks point into .pnpm/
for name in express ms picocolors typescript semver; do
  target=$(readlink "$NM/$name" 2>/dev/null || echo "")
  if [[ "$target" != *".pnpm/"* ]]; then
    echo "FAIL: $name top-level link doesn't point to .pnpm/"
    exit 1
  fi
done
echo "  top-level symlinks correctly point into .pnpm/"
echo "OK: pnpm layout structure correct"

echo ""
echo "--- Test 8: platform packages (@esbuild/darwin-arm64) ---"
arch=$(uname -m)
os=$(uname -s | tr '[:upper:]' '[:lower:]')
if [ "$arch" = "arm64" ] && [ "$os" = "darwin" ]; then
  plat_pkg="@esbuild/darwin-arm64"
elif [ "$arch" = "x86_64" ] && [ "$os" = "darwin" ]; then
  plat_pkg="@esbuild/darwin-x64"
elif [ "$arch" = "x86_64" ] && [ "$os" = "linux" ]; then
  plat_pkg="@esbuild/linux-x64"
elif [ "$arch" = "aarch64" ] && [ "$os" = "linux" ]; then
  plat_pkg="@esbuild/linux-arm64"
else
  plat_pkg=""
fi

if [ -n "$plat_pkg" ]; then
  safe_name=$(echo "$plat_pkg" | sed 's/@//g; s/\//--/g')
  nix_file="$root/nix/node/${safe_name}.nix"

  # Check host platform .nix has real hash (non-empty sha256)
  if grep -q 'sha256 = "";' "$nix_file"; then
    echo "FAIL: host platform $plat_pkg has empty sha256"
    exit 1
  fi
  echo "  $plat_pkg: has real hash"

  # Check wrong-platform has empty hash
  wrong_file="$root/nix/node/esbuild--aix-ppc64.nix"
  if [ -f "$wrong_file" ]; then
    if grep -q 'sha256 = "";' "$wrong_file"; then
      echo "  @esbuild/aix-ppc64: has empty hash (correct — wrong platform)"
    else
      echo "  @esbuild/aix-ppc64: has real hash (expected empty for wrong platform)"
    fi
  fi

  # Check os/cpu metadata present in platform package
  if grep -q 'os = \[' "$nix_file" && grep -q 'cpu = \[' "$nix_file"; then
    echo "  $plat_pkg: has os/cpu metadata"
  else
    echo "FAIL: $plat_pkg missing os/cpu metadata"
    exit 1
  fi

  # Count esbuild variants: only host platform(s) should have real hashes
  real_count=0
  empty_count=0
  for f in "$root"/nix/node/esbuild--*.nix; do
    if grep -q 'sha256 = "";' "$f"; then
      empty_count=$((empty_count + 1))
    else
      real_count=$((real_count + 1))
    fi
  done
  echo "  esbuild variants: $real_count real, $empty_count empty"
  if [ "$real_count" -lt 1 ] || [ "$real_count" -gt 3 ]; then
    echo "FAIL: expected 1-3 real esbuild hashes (host platform), got $real_count"
    exit 1
  fi

  # Verify esbuild binary works (confirms correct platform variant linked)
  tmpjs=$(mktemp /tmp/esbuild-test-XXXXXX.js)
  echo 'console.log("ok")' > "$tmpjs"
  if "$NM/.bin/esbuild" --bundle "$tmpjs" --outfile=/dev/null 2>/dev/null; then
    echo "  esbuild binary executes successfully"
  else
    echo "FAIL: esbuild binary failed to execute"
    rm -f "$tmpjs"
    exit 1
  fi
  rm -f "$tmpjs"

  echo "OK: platform filtering verified"
fi

echo ""
echo "--- Test 9: lockfile version validation (v6 rejected) ---"
ONIX_ROOT="$(cd "$root/.." && pwd)"
err_output=$(BUNDLE_GEMFILE="$ONIX_ROOT/Gemfile" bundle exec ruby -I"$ONIX_ROOT/lib" -e '
  require "onix/packageset"; require "onix/project"; require "onix/ui"; require "onix/version"
  require "onix/commands/import_pnpm"
  Onix::Commands::ImportPnpm.new.run(["'"$dir/fixtures/v6-lockfile.yaml"'"])
' 2>&1 || true)
if echo "$err_output" | grep -q "Unsupported pnpm lockfile version"; then
  echo "  v6 lockfile correctly rejected"
  echo "OK: lockfile version validation works"
else
  echo "FAIL: v6 lockfile was not rejected"
  echo "  output: $err_output"
  exit 1
fi

echo ""
echo "--- Test 10: --node-version flag propagates to meta and nix ---"
tmpdir=$(mktemp -d)
trap "rm -rf $tmpdir" EXIT

# Import with --node-version 20
(BUNDLE_GEMFILE="$ONIX_ROOT/Gemfile" bundle exec ruby -I"$ONIX_ROOT/lib" -e '
  require "onix/packageset"; require "onix/project"; require "onix/ui"; require "onix/version"
  class Onix::Project; def initialize(r=nil); @root = r || "'"$tmpdir"'"; end; end
  require "onix/commands/import_pnpm"
  Onix::Commands::ImportPnpm.new.run(["--node-version", "20", "--name", "test", "'"$dir/pnpm-lock.yaml"'"])
' 2>&1) > /dev/null

# Check meta header has node:"20"
meta_node=$("$NODE" -e "const m=JSON.parse(require('fs').readFileSync('$tmpdir/packagesets/test.jsonl','utf8').split('\n')[0]); console.log(m.node || 'missing')")
if [ "$meta_node" = "20" ]; then
  echo "  meta header has node:20"
else
  echo "FAIL: meta header node=$meta_node, expected 20"
  exit 1
fi

# Generate and check nix uses nodejs_20
(BUNDLE_GEMFILE="$ONIX_ROOT/Gemfile" bundle exec ruby -I"$ONIX_ROOT/lib" -e '
  require "onix/packageset"; require "onix/project"; require "onix/ui"; require "onix/version"
  class Onix::Project; def initialize(r=nil); @root = r || "'"$tmpdir"'"; end; end
  require "onix/commands/generate"; Onix::Commands::Generate.new.run([])
' 2>&1) > /dev/null

if grep -q "nodejs_20" "$tmpdir/nix/test.nix"; then
  echo "  generated nix uses nodejs_20"
else
  echo "FAIL: generated nix does not use nodejs_20"
  grep "nodejs" "$tmpdir/nix/test.nix" | head -1
  exit 1
fi

# Verify default (no --node-version) uses nodejs_22
(BUNDLE_GEMFILE="$ONIX_ROOT/Gemfile" bundle exec ruby -I"$ONIX_ROOT/lib" -e '
  require "onix/packageset"; require "onix/project"; require "onix/ui"; require "onix/version"
  class Onix::Project; def initialize(r=nil); @root = r || "'"$tmpdir"'"; end; end
  require "onix/commands/import_pnpm"
  Onix::Commands::ImportPnpm.new.run(["--name", "test", "'"$dir/pnpm-lock.yaml"'"])
' 2>&1) > /dev/null
(BUNDLE_GEMFILE="$ONIX_ROOT/Gemfile" bundle exec ruby -I"$ONIX_ROOT/lib" -e '
  require "onix/packageset"; require "onix/project"; require "onix/ui"; require "onix/version"
  class Onix::Project; def initialize(r=nil); @root = r || "'"$tmpdir"'"; end; end
  require "onix/commands/generate"; Onix::Commands::Generate.new.run([])
' 2>&1) > /dev/null

if grep -q "nodejs_22" "$tmpdir/nix/test.nix"; then
  echo "  default (no flag) uses nodejs_22"
else
  echo "FAIL: default does not use nodejs_22"
  exit 1
fi

echo "OK: --node-version flag works"

echo ""
echo "--- Test 11: platform matching unit tests ---"
BUNDLE_GEMFILE="$ONIX_ROOT/Gemfile" bundle exec ruby -I"$ONIX_ROOT/lib" -e '
require "onix/packageset"
require "onix/commands/generate_node"
require "onix/ui"

# Wrap in a test class to access private methods
class PlatformTest
  include Onix::Commands::NodeGenerator

  def run_tests
    test_matches_constraint
    test_platform_matches
    test_resolve_target_platforms
    puts "OK: platform matching unit tests passed"
  end

  def assert(cond, msg)
    raise "FAIL: #{msg}" unless cond
  end

  def refute(cond, msg)
    raise "FAIL: #{msg}" if cond
  end

  def test_matches_constraint
    # Positive match
    assert matches_constraint?(["darwin"], "darwin"), "darwin should match darwin"
    # Positive miss
    refute matches_constraint?(["darwin"], "linux"), "darwin should not match linux"
    # Negation match (not win32, and we are darwin)
    assert matches_constraint?(["!win32"], "darwin"), "!win32 should match darwin"
    # Negation miss (not darwin, and we are darwin)
    refute matches_constraint?(["!darwin"], "darwin"), "!darwin should not match darwin"
    # Multiple constraints (any match wins)
    assert matches_constraint?(["linux", "darwin"], "darwin"), "linux|darwin should match darwin"
    refute matches_constraint?(["linux", "win32"], "darwin"), "linux|win32 should not match darwin"
    puts "  matches_constraint?: 6/6 passed"
  end

  def test_platform_matches
    # Cross-platform (empty os and cpu) always passes
    entry = Onix::Packageset::Entry.new(os: [], cpu: [])
    assert platform_matches?(entry, [["darwin", "arm64"]]), "empty os/cpu should always match"

    # Matching platform
    entry = Onix::Packageset::Entry.new(os: ["darwin"], cpu: ["arm64"])
    assert platform_matches?(entry, [["darwin", "arm64"]]), "darwin/arm64 should match"

    # Non-matching platform
    refute platform_matches?(entry, [["linux", "x64"]]), "darwin/arm64 should not match linux/x64"

    # os-only constraint (cpu empty = any cpu)
    entry = Onix::Packageset::Entry.new(os: ["darwin"], cpu: [])
    assert platform_matches?(entry, [["darwin", "x64"]]), "os-only darwin should match any darwin cpu"
    refute platform_matches?(entry, [["linux", "x64"]]), "os-only darwin should not match linux"

    # Multiple target platforms (any match wins)
    entry = Onix::Packageset::Entry.new(os: ["linux"], cpu: ["x64"])
    assert platform_matches?(entry, [["darwin", "arm64"], ["linux", "x64"]]), "should match second target"

    # Negation in os
    entry = Onix::Packageset::Entry.new(os: ["!win32"], cpu: ["x64"])
    assert platform_matches?(entry, [["linux", "x64"]]), "!win32 should match linux"
    assert platform_matches?(entry, [["darwin", "x64"]]), "!win32 should match darwin"

    puts "  platform_matches?: 8/8 passed"
  end

  def test_resolve_target_platforms
    # --all-platforms returns nil (no filtering)
    assert resolve_target_platforms("all").nil?, "--all-platforms should return nil"

    # nil arg = host only (should return 1 platform)
    result = resolve_target_platforms(nil)
    assert result.is_a?(Array) && result.size == 1, "nil should return host platform only"

    # Valid triple adds to host
    result = resolve_target_platforms("x86_64-linux")
    assert result.size >= 2, "should have host + x86_64-linux"
    assert result.include?(["linux", "x64"]), "should include linux/x64"

    # Multiple triples
    result = resolve_target_platforms("x86_64-linux,aarch64-linux")
    assert result.include?(["linux", "x64"]), "should include linux/x64"
    assert result.include?(["linux", "arm64"]), "should include linux/arm64"

    # Unknown triple raises error
    begin
      resolve_target_platforms("arm64-windows")
      raise "FAIL: should have raised for unknown platform"
    rescue SystemExit
      # UI.fail calls exit — expected
    end

    puts "  resolve_target_platforms: 5/5 passed"
  end
end

PlatformTest.new.run_tests
' 2>&1
if [ $? -ne 0 ]; then
  echo "FAIL: platform matching unit tests failed"
  exit 1
fi

echo ""
echo "--- Test 12: devShell sync + sentinel ---"
# Enter the devShell and verify node_modules is synced to a project directory
devshell_dir=$(mktemp -d)
cp "$dir/package.json" "$devshell_dir/"
cp "$dir/pnpm-lock.yaml" "$devshell_dir/"

# Run the shellHook via nix-shell --run (must cd first — shellHook runs in CWD)
(cd "$devshell_dir" && nix-shell "$dir/devshell.nix" --run '
  # shellHook should have created node_modules/
  if [ ! -d node_modules ]; then
    echo "FAIL: node_modules not created by shellHook"
    exit 1
  fi
  echo "  node_modules/ created by shellHook"

  # Sentinel should exist
  if [ ! -f node_modules/.nix-sentinel ]; then
    echo "FAIL: .nix-sentinel not written"
    exit 1
  fi
  echo "  .nix-sentinel present"

  # Packages should be reachable in .pnpm/ layout
  if [ ! -d node_modules/.pnpm/express@4.21.2/node_modules/express ]; then
    echo "FAIL: express not found in .pnpm/"
    exit 1
  fi
  echo "  express present in .pnpm/"

  # Lockfile should be present
  if [ ! -f node_modules/.pnpm/lock.yaml ]; then
    echo "FAIL: .pnpm/lock.yaml missing"
    exit 1
  fi
  echo "  .pnpm/lock.yaml present"

  # NODE_PATH should point to project node_modules
  if [[ "$NODE_PATH" != *"/node_modules" ]]; then
    echo "FAIL: NODE_PATH=$NODE_PATH (expected */node_modules)"
    exit 1
  fi
  echo "  NODE_PATH set correctly"

  # Module loading should work from project dir
  node -e "require(\"express\")" || { echo "FAIL: require(express) failed"; exit 1; }
  echo "  require(express) works from project dir"

  # Native module should work too
  node -e "const db = require(\"better-sqlite3\")(\":memory:\"); db.exec(\"SELECT 1\")" || { echo "FAIL: better-sqlite3 failed"; exit 1; }
  echo "  better-sqlite3 works from project dir"
') 2>&1
echo "OK: devShell sync + sentinel verified"

echo ""
echo "--- Test 13: devShell sentinel warm start (skip sync) ---"
# Re-enter with existing node_modules — should be instant (no sync message)
sync_output=$(cd "$devshell_dir" && nix-shell "$dir/devshell.nix" --run "
  echo 'ENTERED'
" 2>&1)
if echo "$sync_output" | grep -q "onix: node_modules ready"; then
  echo "FAIL: sync ran on warm start (sentinel should have skipped)"
  exit 1
fi
echo "  re-entry skipped sync (sentinel hit)"
echo "OK: sentinel warm start verified"

echo ""
echo "--- Test 14: pnpm recognizes synced node_modules ---"
(cd "$devshell_dir" && nix-shell "$dir/devshell.nix" --run '
  # .modules.yaml should exist with correct settings
  if [ ! -f node_modules/.modules.yaml ]; then
    echo "FAIL: .modules.yaml not generated"
    exit 1
  fi
  grep -q "storeDir:" node_modules/.modules.yaml || { echo "FAIL: .modules.yaml missing storeDir"; exit 1; }
  grep -q "nodeLinker: isolated" node_modules/.modules.yaml || { echo "FAIL: .modules.yaml missing nodeLinker"; exit 1; }
  echo "  .modules.yaml has storeDir + nodeLinker: isolated"

  # .pnpm/lock.yaml should exist (current lockfile = wanted lockfile)
  if [ ! -f node_modules/.pnpm/lock.yaml ]; then
    echo "FAIL: .pnpm/lock.yaml missing"
    exit 1
  fi
  echo "  .pnpm/lock.yaml present"

  # pnpm install MUST report "Already up to date" after onix sync
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "FAIL: pnpm not available — required for this test"
    exit 1
  fi
  pnpm_output=$(pnpm install 2>&1 || true)
  if ! echo "$pnpm_output" | grep -qi "Already up to date"; then
    echo "  pnpm install output: $pnpm_output"
    echo "FAIL: pnpm install did not report Already up to date after sync"
    exit 1
  fi
  echo "  pnpm install: Already up to date"

  # Verify each package variation still works after pnpm accepts the tree

  # Pure JS package
  node -e "const ms = require(\"ms\"); if (ms(3600000) !== \"1h\") throw new Error(\"ms failed\")" \
    || { echo "FAIL: pure JS package (ms) broken"; exit 1; }
  echo "  pure JS (ms): ok"

  # Scoped package
  node -e "const p = require(\"@types/node/package.json\"); if (!p.name.startsWith(\"@types/\")) throw new Error()" \
    || { echo "FAIL: scoped package (@types/node) broken"; exit 1; }
  echo "  scoped (@types/node): ok"

  # Transitive deps
  node -e "const s = require(\"semver\"); if (!s.valid(\"1.2.3\")) throw new Error()" \
    || { echo "FAIL: transitive deps (semver) broken"; exit 1; }
  echo "  transitive deps (semver): ok"

  # Deep dependency tree (express boots an HTTP server)
  node -e "require(\"express\")" \
    || { echo "FAIL: deep dep tree (express) broken"; exit 1; }
  echo "  deep dep tree (express): ok"

  # Native extension (compiled .node binary)
  node -e "const db = require(\"better-sqlite3\")(\":memory:\"); db.exec(\"SELECT 1\")" \
    || { echo "FAIL: native extension (better-sqlite3) broken"; exit 1; }
  echo "  native extension (better-sqlite3): ok"

  # Bin entries
  if [ -L node_modules/.bin/tsc ]; then
    node node_modules/.bin/tsc --version >/dev/null 2>&1 \
      || { echo "FAIL: bin entry (tsc) broken"; exit 1; }
    echo "  bin entry (tsc): ok"
  fi

  # Platform-specific package (esbuild binary)
  if [ -L node_modules/.bin/esbuild ]; then
    tmpjs=$(mktemp /tmp/esbuild-test-XXXXXX.js)
    echo "console.log(42)" > "$tmpjs"
    node_modules/.bin/esbuild --bundle "$tmpjs" --outfile=/dev/null 2>/dev/null \
      || { echo "FAIL: platform package (esbuild) broken"; rm -f "$tmpjs"; exit 1; }
    rm -f "$tmpjs"
    echo "  platform binary (esbuild): ok"
  fi
') 2>&1
echo "OK: pnpm recognizes synced node_modules"

echo ""
echo "--- Test 15: pnpm add/update after sync ---"
# Developers need to iterate with pnpm between onix runs.
# Verify pnpm can add a new package and update an existing one
# on top of the onix-synced node_modules.
(cd "$devshell_dir" && nix-shell "$dir/devshell.nix" --run '
  # Add a new package not in the original lockfile
  pnpm_output=$(pnpm add is-odd 2>&1 || true)
  if echo "$pnpm_output" | grep -qi "error"; then
    echo "  pnpm add output: $pnpm_output"
    echo "FAIL: pnpm add is-odd failed"
    exit 1
  fi
  node -e "if (require(\"is-odd\")(3) !== true) throw new Error()" \
    || { echo "FAIL: newly added package (is-odd) not usable"; exit 1; }
  echo "  pnpm add is-odd: ok"

  # Existing packages still work after add
  node -e "require(\"express\")" \
    || { echo "FAIL: express broken after pnpm add"; exit 1; }
  node -e "const db = require(\"better-sqlite3\")(\":memory:\"); db.exec(\"SELECT 1\")" \
    || { echo "FAIL: better-sqlite3 broken after pnpm add"; exit 1; }
  echo "  existing packages still work after add"

  # Update an existing package (use --latest to force a lockfile change)
  pnpm_output=$(pnpm update ms 2>&1 || true)
  if echo "$pnpm_output" | grep -qi "error"; then
    echo "  pnpm update output: $pnpm_output"
    echo "FAIL: pnpm update ms failed"
    exit 1
  fi
  node -e "require(\"ms\")" \
    || { echo "FAIL: updated package (ms) not usable"; exit 1; }
  echo "  pnpm update ms: ok"

  # Remove the test package to clean up
  pnpm remove is-odd 2>&1 >/dev/null || true
') 2>&1
echo "OK: pnpm add/update after sync works"

echo ""
echo "--- Test 16: sentinel miss (deps changed) ---"
# Write a fake sentinel to simulate a derivation change, then re-enter
(cd "$devshell_dir" && echo "/nix/store/fake-old-derivation" > node_modules/.nix-sentinel)
sync_output=$(cd "$devshell_dir" && nix-shell "$dir/devshell.nix" --run '
  echo "ENTERED"
' 2>&1)
if ! echo "$sync_output" | grep -q "onix: node_modules ready"; then
  echo "FAIL: sync did not run after sentinel mismatch"
  exit 1
fi
echo "  stale sentinel triggered re-sync"

# Verify the sentinel was updated to the new derivation path
sentinel_val=$(cat "$devshell_dir/node_modules/.nix-sentinel")
if [ "$sentinel_val" = "/nix/store/fake-old-derivation" ]; then
  echo "FAIL: sentinel was not updated after re-sync"
  exit 1
fi
echo "  sentinel updated to current derivation"

# Verify modules still work after re-sync
(cd "$devshell_dir" && nix-shell "$dir/devshell.nix" --run '
  node -e "require(\"express\")" || { echo "FAIL: require(express) failed after re-sync"; exit 1; }
  echo "  require(express) works after re-sync"
') 2>&1
echo "OK: sentinel miss (deps changed) verified"

echo ""
echo "--- Test 17: no-pnpm fallback ---"
# Enter devShell with pnpm removed from PATH — sync should work, metadata skipped
nopnpm_dir=$(mktemp -d)
cp "$dir/package.json" "$nopnpm_dir/"
cp "$dir/pnpm-lock.yaml" "$nopnpm_dir/"

(cd "$nopnpm_dir" && nix-shell --pure "$dir/devshell.nix" --run '
  # node_modules should still be created (sync works without pnpm)
  if [ ! -d node_modules ]; then
    echo "FAIL: node_modules not created without pnpm"
    exit 1
  fi
  echo "  node_modules/ created without pnpm"

  # Sentinel should still be written
  if [ ! -f node_modules/.nix-sentinel ]; then
    echo "FAIL: sentinel not written without pnpm"
    exit 1
  fi
  echo "  sentinel written without pnpm"

  # Module loading should still work
  node -e "require(\"express\")" || { echo "FAIL: require(express) failed without pnpm"; exit 1; }
  echo "  require(express) works without pnpm"

  # Metadata files should NOT exist (pnpm was not available)
  if [ -f node_modules/.modules.yaml ]; then
    echo "FAIL: .modules.yaml should not exist without pnpm"
    exit 1
  fi
  echo "  .modules.yaml correctly absent (no pnpm)"

  if [ -f node_modules/.pnpm-workspace-state-v1.json ]; then
    echo "FAIL: workspace state should not exist without pnpm"
    exit 1
  fi
  echo "  workspace state correctly absent (no pnpm)"
') 2>&1
chmod -R u+w "$nopnpm_dir" 2>/dev/null; rm -rf "$nopnpm_dir"
echo "OK: no-pnpm fallback verified"

echo ""
echo "--- Test 18: user shellHook passthrough ---"
# Create a devshell.nix that passes a custom shellHook
custom_devshell=$(mktemp -d)/devshell.nix
cat > "$custom_devshell" << NIXEOF
{ pkgs ? import <nixpkgs> {}, nodejs ? pkgs.nodejs_22 }:
let
  project = import $root/nix/node-basic.nix { inherit pkgs nodejs; };
in project.devShell {
  shellHook = ''
    export ONIX_TEST_CUSTOM_HOOK="it-works"
  '';
}
NIXEOF

hook_dir=$(mktemp -d)
cp "$dir/package.json" "$hook_dir/"
cp "$dir/pnpm-lock.yaml" "$hook_dir/"

hook_output=$(cd "$hook_dir" && nix-shell "$custom_devshell" --run '
  echo "CUSTOM_HOOK=$ONIX_TEST_CUSTOM_HOOK"
' 2>&1)
if echo "$hook_output" | grep -q "CUSTOM_HOOK=it-works"; then
  echo "  user shellHook executed after sync"
else
  echo "FAIL: user shellHook not executed (expected ONIX_TEST_CUSTOM_HOOK=it-works)"
  echo "  output: $hook_output"
  exit 1
fi
chmod -R u+w "$hook_dir" 2>/dev/null; rm -rf "$hook_dir"
rm -f "$custom_devshell"; rmdir "$(dirname "$custom_devshell")" 2>/dev/null
echo "OK: user shellHook passthrough verified"

chmod -R u+w "$devshell_dir" 2>/dev/null; rm -rf "$devshell_dir"

echo ""
echo "--- Test 19: syncScript builds (writeShellApplication) ---"
# Build the syncScript derivation — verifies shellcheck passes at build time
SYNC_SCRIPT=$(nix-build --no-out-link -E "(import $root/nix/node-basic.nix {}).syncScript" 2>&1)
if [ $? -ne 0 ]; then
  echo "FAIL: syncScript failed to build"
  echo "  output: $SYNC_SCRIPT"
  exit 1
fi
if [ ! -x "$SYNC_SCRIPT/bin/node-basic-onix-sync" ]; then
  echo "FAIL: syncScript binary not found at $SYNC_SCRIPT/bin/node-basic-onix-sync"
  exit 1
fi
echo "  syncScript built successfully (shellcheck passed)"
echo "  binary: $SYNC_SCRIPT/bin/node-basic-onix-sync"
echo "OK: syncScript builds"

echo ""
echo "--- Test 20: syncScript syncs node_modules ---"
# Run the standalone sync script in a fresh directory
sync_dir=$(mktemp -d)
cp "$dir/package.json" "$sync_dir/"
cp "$dir/pnpm-lock.yaml" "$sync_dir/"

sync_output=$(cd "$sync_dir" && "$SYNC_SCRIPT/bin/node-basic-onix-sync" 2>&1)
if [ $? -ne 0 ]; then
  echo "FAIL: syncScript exited with error"
  echo "  output: $sync_output"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi

# node_modules should be created
if [ ! -d "$sync_dir/node_modules" ]; then
  echo "FAIL: syncScript did not create node_modules"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi
echo "  node_modules/ created by syncScript"

# Sentinel should exist
if [ ! -f "$sync_dir/node_modules/.nix-sentinel" ]; then
  echo "FAIL: syncScript did not write sentinel"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi
echo "  .nix-sentinel present"

# Packages should be reachable
if [ ! -d "$sync_dir/node_modules/.pnpm/express@4.21.2/node_modules/express" ]; then
  echo "FAIL: express not found in .pnpm/ after syncScript"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi
echo "  express present in .pnpm/"

# Module loading should work
NODE_PATH="$sync_dir/node_modules" "$NODE" -e "require('express')" || {
  echo "FAIL: require(express) failed after syncScript"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
}
echo "  require(express) works after syncScript"

# Ready message should appear
if ! echo "$sync_output" | grep -q "onix: node_modules ready"; then
  echo "FAIL: syncScript did not print ready message"
  echo "  output: $sync_output"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi
echo "  ready message printed"
echo "OK: syncScript syncs node_modules"

echo ""
echo "--- Test 21: syncScript sentinel warm start ---"
# Re-run syncScript — should skip sync (sentinel hit)
warm_output=$(cd "$sync_dir" && "$SYNC_SCRIPT/bin/node-basic-onix-sync" 2>&1)
if echo "$warm_output" | grep -q "onix: node_modules ready"; then
  echo "FAIL: syncScript re-synced on warm start (sentinel should have skipped)"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi
echo "  re-run skipped sync (sentinel hit)"

# Invalidate sentinel and verify re-sync
echo "/nix/store/fake-stale-drv" > "$sync_dir/node_modules/.nix-sentinel"
resync_output=$(cd "$sync_dir" && "$SYNC_SCRIPT/bin/node-basic-onix-sync" 2>&1)
if ! echo "$resync_output" | grep -q "onix: node_modules ready"; then
  echo "FAIL: syncScript did not re-sync after sentinel mismatch"
  echo "  output: $resync_output"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
fi
echo "  stale sentinel triggered re-sync"

# Verify modules still work after re-sync
NODE_PATH="$sync_dir/node_modules" "$NODE" -e "require('express')" || {
  echo "FAIL: require(express) failed after syncScript re-sync"
  chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
  exit 1
}
echo "  require(express) works after re-sync"
chmod -R u+w "$sync_dir" 2>/dev/null; rm -rf "$sync_dir"
echo "OK: syncScript sentinel warm start verified"

echo ""
echo "All node-basic tests passed."
